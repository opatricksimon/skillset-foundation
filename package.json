{
  "name": "skillset-foundation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --project demo-skillset-rules-test --only firestore,storage \"npm run test:rules:run\"",
    "test:rules:run": "vitest run --config vitest.rules.config.ts",
    "test:watch": "vitest",
    "deploy:app": "firebase deploy --only functions,hosting --project skillsetusaofficial",
    "predeploy:app": "node scripts/predeploy-reminder.mjs",
    "deploy:rules": "firebase deploy --only storage,firestore:rules --project skillsetusaofficial",
    "deploy:full": "npm run deploy:app && npm run deploy:rules",
    "deploy:hosting": "npm run deploy:app"
  },
  "dependencies": {
    "@stripe/connect-js": "^3.4.5",
    "@stripe/react-connect-js": "^3.4.3",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.7.0",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "^0.553.0",
    "next": "^16.2.6",
    "posthog-js": "^1.376.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "firebase-tools": "^15.18.0",
    "jsdom": "^27.0.1",
    "stripe": "^22.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "postcss": "8.5.15",
    "uuid": "11.1.1",
    "ws": "8.21.0"
  }
}
