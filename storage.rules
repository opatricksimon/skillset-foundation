rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userHasRole(role) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.roles.hasAny([role]);
    }

    function isAdmin() {
      return userHasRole('admin');
    }

    function courseExists(courseId) {
      return firestore.exists(/databases/(default)/documents/courses/$(courseId));
    }

    function courseData(courseId) {
      return firestore.get(/databases/(default)/documents/courses/$(courseId)).data;
    }

    function ownsCourse(courseId) {
      return signedIn()
        && courseExists(courseId)
        && courseData(courseId).ownerId == request.auth.uid;
    }

    function hasEnrollmentForCourse(courseId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/enrollments/$(request.auth.uid + '__' + courseId))
        && firestore.get(/databases/(default)/documents/enrollments/$(request.auth.uid + '__' + courseId)).data.status in ['active', 'completed'];
    }

    function courseIsEditableByOwner(courseId) {
      return ownsCourse(courseId)
        && courseData(courseId).status in ['draft', 'needs_changes', 'published', 'inactive'];
    }

    function validUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 500 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('text/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    match /courses/{courseId}/assets/{ownerId}/{assetId}/{fileName} {
      allow read: if isAdmin() || ownsCourse(courseId) || hasEnrollmentForCourse(courseId);
      allow write: if signedIn()
        && ownerId == request.auth.uid
        && courseIsEditableByOwner(courseId)
        && validUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
