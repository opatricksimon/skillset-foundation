NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe client-side publishable key only. Safe to expose in browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PAYMENTS_CHECKOUT_ENABLED=false

# PostHog product analytics (client-side). Key from the PostHog project
# settings; analytics stay disabled when unset. Host is optional and
# defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Server-side Stripe secrets (sk_*, whsec_*) are NOT set here. They live in
# Firebase Functions secrets, never in client env or the repo.
