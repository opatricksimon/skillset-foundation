# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.firebase/

# production
/build
/functions/lib/
/tmp-skillset-bootstrap/

# misc
.DS_Store
*.pem
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
firestore-debug.*.log
storage-debug.log
storage-debug.*.log
ui-debug.log
ui-debug.*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!functions/.env.example
# .env.production carries ONLY publishable NEXT_PUBLIC_* values that are
# safe to ship in the browser bundle (e.g. PostHog phc_ project key).
# Server secrets stay out — see file header.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
